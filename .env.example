CITY_NAME=Hyderabad
DATA_ROOT=data
USER_AGENT=HyderabadCityKnowledgeCollector/0.1 contact=you@example.com
MAX_DEPTH=3
MAX_CANDIDATES_PER_RUN=50
REQUEST_DELAY_SECONDS=1.2
RESPECT_ROBOTS=true

# Optional official Google Programmable Search integration.
# Required for `google_search` candidates. The collector does not scrape
# Google result pages.
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
WEB_SEARCH_RESULTS_PER_QUERY=10
WEB_PAGE_MAX_LINKS=20
WEB_PAGE_MAX_CHARS=12000
