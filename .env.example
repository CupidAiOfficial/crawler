CITY_NAME=Hyderabad
DATA_ROOT=data
USER_AGENT=HyderabadCityKnowledgeCollector/0.1 contact=you@example.com
MAX_DEPTH=3
MAX_CANDIDATES_PER_RUN=50
CRAWLER_WORKERS=4
REQUEST_DELAY_SECONDS=1.2
MAX_RETRY_AFTER_SECONDS=120
RESPECT_ROBOTS=true

# Optional official Google Programmable Search integration.
# Required for `google_search` candidates. The collector does not scrape
# Google result pages.
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
WEB_SEARCH_RESULTS_PER_QUERY=10
WEB_PAGE_MAX_LINKS=20
WEB_PAGE_MAX_CHARS=12000
WEB_PAGE_MIN_TEXT_CHARS=500

# Optional local/self-hosted Firecrawl integration.
FIRECRAWL_BASE_URL=http://localhost:3002
FIRECRAWL_API_KEY=
FIRECRAWL_SEARCH_LIMIT=10
FIRECRAWL_SCRAPE_FORMATS=["markdown","html"]

# Local Cupid backend Postgres export target.
DATABASE_URL=postgresql://admin:123@localhost:5432/cupidaidb

# Console logging for crawler steps: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Image blob storage limits for app-serving cards.
IMAGE_DOWNLOAD_TIMEOUT_SECONDS=20
IMAGE_DOWNLOAD_MAX_BYTES=5000000
